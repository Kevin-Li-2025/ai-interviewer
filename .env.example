# --- Option A: DeepSeek (OpenAI-compatible, recommended for cost) ---
DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_FAST=deepseek-chat
# Optional: deepseek-reasoner for heavier "slow lane"
# DEEPSEEK_MODEL_SLOW=deepseek-reasoner

# --- Option B: OpenAI (if DEEPSEEK_API_KEY is unset) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_FAST=gpt-4o-mini
# OPENAI_MODEL_SLOW=gpt-4o
# Optional: OpenAI-only TTS (needs OPENAI_API_KEY; DeepSeek cannot do this)
# OPENAI_TTS=1
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy
PORT=8787
# Eval: EVAL_BASE=http://127.0.0.1:8787
